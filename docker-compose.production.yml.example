services:
  app-postgres:
    image: postgres:16
    environment:
      POSTGRES_USER: ${APP_DB_USER}
      POSTGRES_PASSWORD: ${APP_DB_PASSWORD}
      POSTGRES_DB: ${APP_DB_NAME}
    volumes:
      - app_pg:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${APP_DB_USER} -d ${APP_DB_NAME}"]
      interval: 10s
      timeout: 5s
      retries: 10

  temporal-postgres:
    image: postgres:16
    environment:
      POSTGRES_USER: ${TEMPORAL_DB_USER}
      POSTGRES_PASSWORD: ${TEMPORAL_DB_PASSWORD}
      POSTGRES_DB: ${TEMPORAL_DB_NAME}
    volumes:
      - temporal_pg:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${TEMPORAL_DB_USER} -d ${TEMPORAL_DB_NAME}"]
      interval: 10s
      timeout: 5s
      retries: 10

  temporal:
    image: temporalio/auto-setup:1.25
    environment:
      DB: postgres12
      DB_PORT: 5432
      POSTGRES_USER: ${TEMPORAL_DB_USER}
      POSTGRES_PWD: ${TEMPORAL_DB_PASSWORD}
      POSTGRES_SEEDS: temporal-postgres
    depends_on:
      temporal-postgres:
        condition: service_healthy
    restart: unless-stopped

  temporal-ui:
    image: temporalio/ui:2.37.2
    environment:
      TEMPORAL_ADDRESS: temporal:7233
    depends_on:
      temporal:
        condition: service_started
    restart: unless-stopped

  init:
    build:
      context: .
    env_file:
      - .env.production
    environment:
      DATABASE_URL: postgresql://${APP_DB_USER}:${APP_DB_PASSWORD}@app-postgres:5432/${APP_DB_NAME}
      TEMPORAL_ADDRESS: temporal:7233
      NEXTAUTH_URL: ${NEXTAUTH_URL}
      PRISMA_AUTO_REPAIR_SCHEMA: "false"
    depends_on:
      app-postgres:
        condition: service_healthy
      temporal:
        condition: service_started
    command: ["npm", "run", "prisma:init"]
    restart: "no"

  web:
    build:
      context: .
    env_file:
      - .env.production
    environment:
      DATABASE_URL: postgresql://${APP_DB_USER}:${APP_DB_PASSWORD}@app-postgres:5432/${APP_DB_NAME}
      TEMPORAL_ADDRESS: temporal:7233
      NEXTAUTH_URL: ${NEXTAUTH_URL}
    depends_on:
      app-postgres:
        condition: service_healthy
      init:
        condition: service_completed_successfully
    restart: unless-stopped

  worker:
    build:
      context: .
    env_file:
      - .env.production
    environment:
      DATABASE_URL: postgresql://${APP_DB_USER}:${APP_DB_PASSWORD}@app-postgres:5432/${APP_DB_NAME}
      TEMPORAL_ADDRESS: temporal:7233
    depends_on:
      app-postgres:
        condition: service_healthy
      temporal:
        condition: service_started
      init:
        condition: service_completed_successfully
    command: ["npm", "run", "worker"]
    restart: unless-stopped

volumes:
  app_pg:
  temporal_pg:
