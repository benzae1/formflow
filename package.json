{
  "name": "formflow",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "worker": "tsx src/temporal/worker.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "verify": "npm run test:integration && npm run test:e2e",
    "verify:smoke": "npm run lint && npm run build && npm run test:integration && npm run test:e2e -- --grep @smoke",
    "verify:stack": "node tests/scripts/wait-for-stack.mjs && npm run verify"
  },
  "dependencies": {
    "@formio/core": "^2.6.0",
    "@formio/js": "^5.3.0",
    "@formio/react": "^6.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@temporalio/activity": "^1.17.0",
    "@temporalio/client": "^1.17.0",
    "@temporalio/worker": "^1.17.0",
    "@temporalio/workflow": "^1.17.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "expr-eval": "^2.0.2",
    "formiojs": "^4.21.7",
    "ldapts": "^8.1.7",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  }
}
