generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FormStatus {
  draft
  published
  archived
}

enum FormSensitivity {
  standard
  pii
  sensitive
}

enum SubmissionStatus {
  draft
  submitted
  in_review
  needs_revision
  approved
  rejected
  closed
}

enum ApprovalTaskStatus {
  pending
  approved
  rejected
  revision_requested
  cancelled
}

enum NotificationChannel {
  email
  in_app
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  roles         Role[]    @relation("UserRoles")
  externalId    String?
  passwordHash  String?
  failedLoginCount Int    @default(0)
  lastFailedLoginAt DateTime?
  lockedUntil   DateTime?
  sessionVersion Int      @default(0)
  deactivatedAt DateTime?
  teamScope     Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  formsCreated  Form[]    @relation("FormCreatedBy")
  workflows     Workflow[]
  submissions   Submission[]
  approvalTasks ApprovalTask[]
  memberships   OrgMembership[]
  delegationsFrom Delegation[] @relation("DelegationApprover")
  delegationsTo   Delegation[] @relation("DelegationDelegate")
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  label     String?
  createdAt DateTime @default(now())
  users     User[]   @relation("UserRoles")
  forms     Form[]   @relation("FormAllowedRoles")
}

model Form {
  id            String          @id @default(uuid())
  slug          String          @unique
  title         String
  schema        Json
  translations  Json?
  version       Int             @default(1)
  status        FormStatus      @default(draft)
  sensitivity   FormSensitivity @default(standard)

  workflowId    String?
  workflow      Workflow?       @relation(fields: [workflowId], references: [id])

  parentFormId  String?
  parentForm    Form?           @relation("ParentChildForms", fields: [parentFormId], references: [id])
  childForms    Form[]          @relation("ParentChildForms")

  createdById   String
  createdBy     User            @relation("FormCreatedBy", fields: [createdById], references: [id])
  // Empty allowedRoles means any authenticated user may see and submit the published form.
  allowedRoles  Role[]          @relation("FormAllowedRoles")

  versions      FormVersion[]
  submissions   Submission[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model FormVersion {
  id        String   @id @default(uuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id])
  version   Int
  schema    Json
  translations Json?

  createdAt DateTime @default(now())

  @@unique([formId, version])
}

model Workflow {
  id          String   @id @default(uuid())
  name        String
  definition  Json
  version     Int      @default(1)

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  forms       Form[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Submission {
  id                  String           @id @default(uuid())
  formId              String
  form                Form             @relation(fields: [formId], references: [id])

  formVersion         Int
  formSchemaSnapshot  Json?
  submittedLocale     String           @default("de")
  submittedById       String
  submittedBy         User             @relation(fields: [submittedById], references: [id])

  data                Json
  status              SubmissionStatus @default(draft)
  workflowRunId       String?
  workflowId          String?
  workflowVersion     Int?
  workflowDefinition  Json?

  parentSubmissionId  String?
  parentSubmission    Submission?      @relation("ParentChildSubmissions", fields: [parentSubmissionId], references: [id])
  childSubmissions    Submission[]     @relation("ParentChildSubmissions")

  approvalTasks       ApprovalTask[]
  retainUntil         DateTime?
  purgeAt             DateTime?
  deletedAt           DateTime?

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([retainUntil])
  @@index([purgeAt])
}

model ApprovalTask {
  id            String             @id @default(uuid())
  submissionId  String
  submission    Submission         @relation(fields: [submissionId], references: [id])

  stageIndex    Int
  assignedToId  String
  assignedTo    User               @relation(fields: [assignedToId], references: [id])

  status        ApprovalTaskStatus @default(pending)
  decisionAt    DateTime?
  note          String?
  dueAt         DateTime?
  retainUntil   DateTime?
  purgeAt       DateTime?

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([retainUntil])
  @@index([purgeAt])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String
  title       String
  body        String
  linkUrl     String?
  readAt      DateTime?
  purgeAt     DateTime?

  createdAt   DateTime @default(now())

  @@index([purgeAt])
}

model OrgUnit {
  id          String    @id @default(uuid())
  name        String
  type        String
  externalId  String    @unique

  parentId    String?
  parent      OrgUnit?  @relation("OrgTree", fields: [parentId], references: [id])
  children    OrgUnit[] @relation("OrgTree")

  memberships OrgMembership[]
}

model OrgMembership {
  id          String  @id @default(uuid())

  userId      String
  user        User    @relation(fields: [userId], references: [id])

  orgUnitId   String
  orgUnit     OrgUnit @relation(fields: [orgUnitId], references: [id])

  roleInUnit  String?
  isManager   Boolean @default(false)

  @@unique([userId, orgUnitId])
}

model Delegation {
  id             String   @id @default(uuid())
  approverId     String
  approver       User     @relation("DelegationApprover", fields: [approverId], references: [id])
  delegateId     String
  delegate       User     @relation("DelegationDelegate", fields: [delegateId], references: [id])
  startsAt       DateTime
  endsAt         DateTime

  createdAt      DateTime @default(now())
}

model AuditLog {
  id            String   @id @default(uuid())
  actorId       String?
  action        String
  resourceType  String
  resourceId    String
  beforeState   Json?
  afterState    Json?
  metadata      Json?
  retainUntil   DateTime?
  exportedForDsarAt DateTime?

  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([resourceType, resourceId, createdAt])
  @@index([action, createdAt])
  @@index([retainUntil])
}

model LoginRateLimitBucket {
  key        String   @id
  count      Int
  resetAt    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([resetAt])
}

